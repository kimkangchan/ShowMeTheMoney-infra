# DB 설정 (AWS RDS MySQL)
# DB_HOST에 RDS 엔드포인트만 입력하면 됨 (나머지 옵션은 application.yml에서 고정 조합)
DB_HOST=<rds-endpoint>
DB_PORT=3306
DB_NAME=showmethemoney
DB_USERNAME=your_rds_username
DB_PASSWORD=your_rds_password

# DB 접속 TLS 모드 (DISABLED / PREFERRED / REQUIRED / VERIFY_CA / VERIFY_IDENTITY)
# 로컬 db 컨테이너: DISABLED, 운영 RDS: REQUIRED
DB_SSL_MODE=REQUIRED

# JWT 설정 (SECRET은 32자 이상 랜덤 문자열 권장: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-256bit-secret-key-before-use
JWT_EXPIRATION=86400

# CORS 허용 Origin 설정
# 로컬: 프론트엔드 개발 서버 주소 (포트 주의)
# 운영: 실제 서비스 도메인 (여러 개는 쉼표로 구분, 공백 없이)
# 예) CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
