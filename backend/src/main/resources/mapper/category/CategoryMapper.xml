<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.showmethemoney.category.infrastructure.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.showmethemoney.category.domain.Category">
        <id property="uuid" column="uuid"/>
        <result property="code" column="code"/>
        <result property="codeNumber" column="code_number"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
    </resultMap>

    <select id="findAll" resultMap="CategoryResultMap">
        SELECT uuid, code, code_number, name, type
        FROM categories
        <where>
            <if test="type != null">AND type = #{type}</if>
        </where>
        ORDER BY type, code_number
    </select>

    <select id="findByCodeAndType" resultMap="CategoryResultMap">
        SELECT uuid, code, code_number, name, type
        FROM categories
        WHERE code = #{code}
          AND type = #{type}
    </select>

</mapper>
