<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.showmethemoney.auth.infrastructure.AuthMapper">

    <resultMap id="UserResultMap" type="com.showmethemoney.user.domain.User">
        <id property="uuid" column="uuid"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <insert id="insertUser" parameterType="com.showmethemoney.user.domain.User" useGeneratedKeys="true" keyProperty="uuid">
        INSERT INTO users (username, email, password, nickname)
        VALUES (#{username}, #{email}, #{password}, #{nickname})
    </insert>

    <select id="findByUsername" resultMap="UserResultMap">
        SELECT uuid, username, email, password, nickname, created_at, updated_at, deleted_at
        FROM users
        WHERE username = #{username}
          AND deleted_at IS NULL
    </select>

    <select id="findByEmail" resultMap="UserResultMap">
        SELECT uuid, username, email, password, nickname, created_at, updated_at, deleted_at
        FROM users
        WHERE email = #{email}
          AND deleted_at IS NULL
    </select>

</mapper>
