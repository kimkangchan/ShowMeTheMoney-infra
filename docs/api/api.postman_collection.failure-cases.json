            "body": { "mode": "raw", "raw": "{\n  \"type\": 0,\n  \"categoryCode\": \"NOPE_CODE\",\n  \"name\": \"x\",\n  \"amount\": 1000,\n  \"billingDay\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/recurring-items", "host": ["{{baseUrl}}"], "path": ["recurring-items"] }
