          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": 0,\n  \"categoryCode\": \"FOOD\",\n  \"name\": \"x\",\n  \"amount\": 1000,\n  \"billingDay\": 35\n}" },
            "url": { "raw": "{{baseUrl}}/recurring-items", "host": ["{{baseUrl}}"], "path": ["recurring-items"] }
          }
