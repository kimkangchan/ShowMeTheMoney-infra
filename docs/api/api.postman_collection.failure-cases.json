{
  "info": {
    "_postman_id": "f4a1c9e2-7d3b-4c6a-9e21-showmethemoney-failure",
    "name": "ShowMeTheMoney API 실패 케이스 (QA)",
    "description": "docs/api/api.md의 '실패 케이스 검증 결과' 섹션과 짝을 이루는 컬렉션. 실패 응답(에러 코드/메시지)이 문서대로 나오는지 스크린샷으로 남기기 위한 용도.\n\n사용 순서:\n1. 컬렉션 변수 baseUrl을 대상 서버로 맞춘다 (기본값: team4 배포서버).\n2. '0. QA 계정 준비' 폴더의 요청을 위에서부터 순서대로 실행한다. accessToken/intruderAccessToken/transactionId/recurringItemId/budgetId가 자동으로 채워진다.\n3. 이후 1~6번 폴더는 순서 상관없이 실행하며 각 응답을 스크린샷으로 캡처한다.\n\n이 컬렉션이 생성하는 계정/데이터는 QA 전용이며 정리하지 않고 남겨두기로 함(2026-07-22 결정).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://team4.mang.pe.kr/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "intruderAccessToken", "value": "", "type": "string" },
    { "key": "qaTs", "value": "", "type": "string" },
    { "key": "qaOwnerUsername", "value": "", "type": "string" },
    { "key": "qaOwnerEmail", "value": "", "type": "string" },
    { "key": "qaIntruderUsername", "value": "", "type": "string" },
    { "key": "qaIntruderEmail", "value": "", "type": "string" },
    { "key": "transactionId", "value": "", "type": "string" },
    { "key": "recurringItemId", "value": "", "type": "string" },
    { "key": "budgetId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. QA 계정 준비 (최초 1회, 순서대로 실행)",
      "item": [
        {
          "name": "0-1. Owner 회원가입",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('qaTs')) {",
                  "    pm.collectionVariables.set('qaTs', Date.now().toString());",
                  "}",
                  "const ts = pm.collectionVariables.get('qaTs');",
                  "pm.collectionVariables.set('qaOwnerUsername', 'apitest_owner_' + ts);",
                  "pm.collectionVariables.set('qaOwnerEmail', 'apitest_owner_' + ts + '@example.com');",
                  "pm.collectionVariables.set('qaIntruderUsername', 'apitest_intruder_' + ts);",
                  "pm.collectionVariables.set('qaIntruderEmail', 'apitest_intruder_' + ts + '@example.com');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{qaOwnerUsername}}\",\n  \"name\": \"QA Owner\",\n  \"email\": \"{{qaOwnerEmail}}\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "0-2. Owner 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{qaOwnerUsername}}\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "0-3. Intruder 회원가입",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{qaIntruderUsername}}\",\n  \"name\": \"QA Intruder\",\n  \"email\": \"{{qaIntruderEmail}}\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "0-4. Intruder 로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.accessToken) {",
                  "    pm.collectionVariables.set('intruderAccessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{qaIntruderUsername}}\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "0-5. Owner 거래 생성 (403 테스트용 리소스)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 0,\n  \"categoryCode\": \"FOOD\",\n  \"amount\": 1000,\n  \"memo\": \"qa\",\n  \"transactionAt\": \"2026-07-20\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "0-6. 거래 목록 조회 (id 확보)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.content && json.data.content[0]) {",
                  "    pm.collectionVariables.set('transactionId', json.data.content[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions?size=1", "host": ["{{baseUrl}}"], "path": ["transactions"], "query": [{ "key": "size", "value": "1" }] }
          }
        },
        {
          "name": "0-7. Owner 고정 항목 생성 (403 테스트용 리소스)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 0,\n  \"categoryCode\": \"FOOD\",\n  \"name\": \"QA rent\",\n  \"amount\": 50000,\n  \"billingDay\": 5\n}"
            },
            "url": { "raw": "{{baseUrl}}/recurring-items", "host": ["{{baseUrl}}"], "path": ["recurring-items"] }
          }
        },
        {
          "name": "0-8. 고정 항목 목록 조회 (id 확보)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data[0]) {",
                  "    pm.collectionVariables.set('recurringItemId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/recurring-items", "host": ["{{baseUrl}}"], "path": ["recurring-items"] }
          }
        },
        {
          "name": "0-9. Owner 예산 설정 203001 (403/409 테스트용 리소스)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"yearMonth\": \"203001\",\n  \"amount\": 100000\n}"
            },
            "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] }
          }
        },
        {
          "name": "0-10. 예산 조회 (id 확보)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('budgetId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/budgets?yearMonth=203001", "host": ["{{baseUrl}}"], "path": ["budgets"], "query": [{ "key": "yearMonth", "value": "203001" }] }
          }
        }
      ]
    },
    {
      "name": "1. Auth 실패 케이스",
      "item": [
        {
          "name": "필수 필드 누락 → 400 INVALID_INPUT",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "이메일 형식 오류 → 400 INVALID_INPUT",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"qafail1\",\n  \"name\": \"n\",\n  \"email\": \"not-an-email\",\n  \"password\": \"12345678\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "비밀번호 8자 미만 → 400 INVALID_INPUT",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"qafail2\",\n  \"name\": \"n\",\n  \"email\": \"qafail2@example.com\",\n  \"password\": \"123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "username 중복 → 409 USERNAME_ALREADY_EXISTS",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{qaOwnerUsername}}\",\n  \"name\": \"n\",\n  \"email\": \"dup-{{qaTs}}@example.com\",\n  \"password\": \"testpass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "email 중복 → 409 EMAIL_ALREADY_EXISTS",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"dupuser-{{qaTs}}\",\n  \"name\": \"n\",\n  \"email\": \"{{qaOwnerEmail}}\",\n  \"password\": \"testpass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "로그인 비밀번호 오류 → 401 INVALID_CREDENTIALS",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{qaOwnerUsername}}\",\n  \"password\": \"wrongpassword\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "존재하지 않는 username → 401 INVALID_CREDENTIALS",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"nouser-{{qaTs}}\",\n  \"password\": \"whatever1\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "2. 공통 인증 실패",
      "item": [
        {
          "name": "토큰 없음 → 401 (본문 없음, Known Limitation)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "잘못된 토큰 → 401 (본문 없음, Known Limitation)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "garbage.invalid.token", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        }
      ]
    },
    {
      "name": "3. Transactions 실패 케이스",
      "item": [
        {
          "name": "필수 필드 누락 → 400 INVALID_INPUT",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "amount 음수 → 400 INVALID_INPUT",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": 0,\n  \"categoryCode\": \"FOOD\",\n  \"amount\": -100,\n  \"transactionAt\": \"2026-07-20\"\n}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "존재하지 않는 categoryCode → 404 CATEGORY_NOT_FOUND",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": 0,\n  \"categoryCode\": \"NOPE_CODE\",\n  \"amount\": 1000,\n  \"transactionAt\": \"2026-07-20\"\n}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "categoryCode-type 불일치 → 404 CATEGORY_NOT_FOUND (TYPE_MISMATCH 아님)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": 1,\n  \"categoryCode\": \"FOOD\",\n  \"amount\": 1000,\n  \"transactionAt\": \"2026-07-20\"\n}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "존재하지 않는 id 조회 → 404 TRANSACTION_NOT_FOUND",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions/999999999", "host": ["{{baseUrl}}"], "path": ["transactions", "999999999"] }
          }
        },
        {
          "name": "다른 유저 소유 id 조회 → 403 FORBIDDEN",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{intruderAccessToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions/{{transactionId}}", "host": ["{{baseUrl}}"], "path": ["transactions", "{{transactionId}}"] }
          }
        },
        {
          "name": "존재하지 않는 id 수정 → 404 TRANSACTION_NOT_FOUND",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 5000\n}" },
            "url": { "raw": "{{baseUrl}}/transactions/999999999", "host": ["{{baseUrl}}"], "path": ["transactions", "999999999"] }
          }
        },
        {
          "name": "다른 유저 소유 id 삭제 → 403 FORBIDDEN",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{intruderAccessToken}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions/{{transactionId}}", "host": ["{{baseUrl}}"], "path": ["transactions", "{{transactionId}}"] }
          }
        },
        {
          "name": "[버그] type=abc → 401 (기대: 400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions?type=abc", "host": ["{{baseUrl}}"], "path": ["transactions"], "query": [{ "key": "type", "value": "abc" }] }
          }
        },
        {
          "name": "[버그] 숫자 아닌 path id → 401 (기대: 400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions/abc", "host": ["{{baseUrl}}"], "path": ["transactions", "abc"] }
          }
        }
      ]
    },
    {
      "name": "4. Recurring Items 실패 케이스",
      "item": [
        {
