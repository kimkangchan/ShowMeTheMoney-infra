        {
          "name": "다른 유저 소유 id 삭제 → 403 FORBIDDEN",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{intruderAccessToken}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/recurring-items/{{recurringItemId}}", "host": ["{{baseUrl}}"], "path": ["recurring-items", "{{recurringItemId}}"] }
          }
        }
      ]
    },
    {
      "name": "5. Budgets 실패 케이스",
      "item": [
        {
          "name": "yearMonth 길이 오류(5자) → 400 INVALID_INPUT",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"yearMonth\": \"20309\",\n  \"amount\": 1000\n}" },
            "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] }
          }
        },
        {
          "name": "같은 달 중복 생성 → 409 BUDGET_ALREADY_EXISTS",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"yearMonth\": \"203001\",\n  \"amount\": 5000\n}" },
            "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] }
          }
        },
        {
          "name": "존재하지 않는 yearMonth 조회 → 404 BUDGET_NOT_FOUND",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/budgets?yearMonth=999912", "host": ["{{baseUrl}}"], "path": ["budgets"], "query": [{ "key": "yearMonth", "value": "999912" }] }
          }
        },
        {
          "name": "다른 유저 소유 id 수정 → 403 FORBIDDEN",
